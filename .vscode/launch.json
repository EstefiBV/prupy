{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Flask (src) - run.py",
            "type": "python",
            "request": "launch",
            "module": "flask",
            "env": {
                "FLASK_APP": "run:app",
                "FLASK_ENV": "development",
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "args": [
                "run",
                "--no-debugger",
                "--no-reload"
            ],
            "jinja": true
        }
    ]
}